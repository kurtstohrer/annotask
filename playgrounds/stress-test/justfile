# Annotask Stress Lab — local dev orchestration.
#
# Usage:
#   cd playgrounds/stress-test && just <recipe>
#   or: just -f playgrounds/stress-test/justfile <recipe>
#
# Run `just list` for the full recipe list.

# Repo root, computed from this justfile's own location. Every recipe cd's
# here before invoking pnpm so workspace-filter scripts resolve correctly.
ROOT := justfile_directory() + "/../.."

# Default recipe — show available commands.
default:
    @just --list --unsorted

# Start native services + host + every MFE. Ctrl-C tears it down.
# Java + Laravel are Docker-only — start with `just compose-up` separately.
up:
    #!/usr/bin/env bash
    set -e
    cd {{ROOT}}
    trap 'jobs -p | xargs -r kill' EXIT INT TERM
    echo "[stress-lab] starting native services..."
    pnpm dev:stress-fastapi   >/tmp/stress-fastapi.log   2>&1 &
    pnpm dev:stress-node-api  >/tmp/stress-node-api.log  2>&1 &
    pnpm dev:stress-go-api    >/tmp/stress-go-api.log    2>&1 &
    pnpm dev:stress-rust-api  >/tmp/stress-rust-api.log  2>&1 &
    sleep 1
    echo "[stress-lab] starting frontends..."
    pnpm dev:stress-host                 >/tmp/stress-host.log    2>&1 &
    pnpm dev:stress-vue-data-lab         >/tmp/stress-vue.log     2>&1 &
    pnpm dev:stress-react-workflows      >/tmp/stress-react.log   2>&1 &
    pnpm dev:stress-svelte-streaming     >/tmp/stress-svelte.log  2>&1 &
    pnpm dev:stress-solid-component-lab  >/tmp/stress-solid.log   2>&1 &
    pnpm dev:stress-htmx-partials        >/tmp/stress-htmx.log    2>&1 &
    sleep 3
    echo
    echo "  Host        http://localhost:4200"
    echo "  Vue         http://localhost:4220   FastAPI  http://localhost:4320"
    echo "  React       http://localhost:4210   Java     http://localhost:4310 (docker)"
    echo "  Svelte      http://localhost:4230   Go       http://localhost:4330"
    echo "  Solid       http://localhost:4240   Node     http://localhost:4340"
    echo "  Blade       http://localhost:4350 (docker — served by Laravel)"
    echo "  htmx        http://localhost:4260   Rust     http://localhost:4360"
    echo
    echo "  Logs: /tmp/stress-*.log   |   Stop: Ctrl-C (or just down)"
    wait

# Kill anything listening on stress-test ports.
down:
    #!/usr/bin/env bash
    for p in 4200 4210 4220 4230 4240 4260 4310 4320 4330 4340 4350 4360; do
        pid=$(lsof -ti:$p 2>/dev/null || true)
        if [ -n "$pid" ]; then
            kill "$pid" 2>/dev/null || true
            echo "[stress-lab] stopped port $p (pid $pid)"
        fi
    done

# Tail all dev-server logs written by `just up`.
logs:
    tail -f /tmp/stress-*.log

# ── Host ────────────────────────────────────────────────

# Host shell (single-spa root) — http://localhost:4200
host:
    cd {{ROOT}} && pnpm dev:stress-host

# ── MFEs ────────────────────────────────────────────────

# Vue data-lab MFE — :4220 (backed by FastAPI :4320)
vue:
    cd {{ROOT}} && pnpm dev:stress-vue-data-lab

# React workflows MFE — :4210 (backed by Java :4310)
react:
    cd {{ROOT}} && pnpm dev:stress-react-workflows

# Svelte streaming MFE — :4230 (backed by Go :4330)
svelte:
    cd {{ROOT}} && pnpm dev:stress-svelte-streaming

# Solid component-lab MFE — :4240 (backed by Node :4340)
solid:
    cd {{ROOT}} && pnpm dev:stress-solid-component-lab

# htmx partials MFE — :4260 (backed by Rust :4360)
htmx:
    cd {{ROOT}} && pnpm dev:stress-htmx-partials

# ── Services (native) ───────────────────────────────────

# FastAPI — :4320
fastapi:
    cd {{ROOT}} && pnpm dev:stress-fastapi

# Node — :4340
node:
    cd {{ROOT}} && pnpm dev:stress-node-api

# Go — :4330
go:
    cd {{ROOT}} && pnpm dev:stress-go-api

# Rust — :4360
rust:
    cd {{ROOT}} && pnpm dev:stress-rust-api

# ── Services (docker-only) ──────────────────────────────

# Java Spring Boot — :4310. First build ~3–5 min.
java:
    cd {{ROOT}} && docker compose -f playgrounds/stress-test/docker-compose.yml up --build java-api

# Laravel — :4350. Serves the Blade slot + JSON API. First build ~3–6 min.
laravel:
    cd {{ROOT}} && docker compose -f playgrounds/stress-test/docker-compose.yml up --build laravel

# ── Docker compose (full stack) ─────────────────────────

# Build + start every compose-wired service (fastapi, node, go, rust, java, laravel).
compose-up:
    cd {{ROOT}} && pnpm stress-test:up

# Stop the compose stack.
compose-down:
    cd {{ROOT}} && pnpm stress-test:down

# ── Tests ───────────────────────────────────────────────

# Run the stress-lab Playwright suite (boots every dev server, runs specs, tears down).
test:
    cd {{ROOT}} && pnpm test:e2e:stress

# ── Meta ────────────────────────────────────────────────

# List recipes
list:
    @just --list --unsorted
