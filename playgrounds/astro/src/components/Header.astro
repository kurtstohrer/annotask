---
interface Props {
  title: string
}
const { title } = Astro.props
---

<header class="header">
  <div class="header-inner">
    <h1 class="logo">{title}</h1>
    <nav class="nav">
      <a href="#planets" class="nav-link">Planets</a>
      <a href="#stats" class="nav-link">Stats</a>
    </nav>
  </div>
</header>

<style>
  .header {
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo { font-size: 18px; font-weight: 600; }
  .nav { display: flex; gap: 24px; }
  .nav-link {
    color: var(--text);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    background: #22c55e;
    padding: 6px 14px;
    border-radius: 6px;
    transition: background 0.15s, color 0.15s;
  }
  .nav-link:hover { background: #16a34a; }
</style>
