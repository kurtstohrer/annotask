{
  "name": "annotask",
  "version": "0.0.24",
  "description": "Visual UI design tool for web apps. Make changes in the browser and generate structured reports that AI agents can apply to source code. Works with Vue, React, Svelte, and plain HTML via Vite or Webpack.",
  "license": "MIT",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "bin": {
    "annotask": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "pnpm build:shell && pnpm build:plugin && pnpm build:vendor",
    "build:shell": "vite build --config vite.config.shell.ts",
    "build:plugin": "tsup",
    "build:vendor": "mkdir -p dist/vendor && cp node_modules/axe-core/axe.min.js dist/vendor/axe-core.min.js && cp node_modules/html2canvas-pro/dist/html2canvas-pro.min.js dist/vendor/html2canvas.min.js",
    "dev:shell": "vite --config vite.config.shell.ts",
    "dev:vue-vite": "pnpm --filter @annotask/playground-vue-vite dev",
    "dev:vue-webpack": "pnpm --filter @annotask/playground-vue-webpack dev",
    "dev:react-vite": "pnpm --filter @annotask/playground-react-vite dev",
    "dev:svelte-vite": "pnpm --filter @annotask/playground-svelte-vite dev",
    "dev:html-vite": "pnpm --filter @annotask/playground-html-vite dev",
    "dev:astro": "pnpm --filter @annotask/playground-astro dev",
    "dev:htmx-vite": "pnpm --filter @annotask/playground-htmx-vite dev",
    "dev:mfe-vite": "pnpm --filter @annotask/playground-mfe-vite dev",
    "dev:antenna-vite": "pnpm --filter @annotask/playground-antenna-vite dev",
    "typecheck": "tsc --noEmit && vue-tsc --noEmit -p src/shell/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "vite": ">=4.0.0",
    "webpack": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/prismjs": "^1.26.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "axe-core": "^4.11.1",
    "dompurify": "^3.3.3",
    "html2canvas-pro": "^2.0.2",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.1",
    "marked": "^17.0.5",
    "prismjs": "^1.30.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.2",
    "vue": "^3.5.0",
    "vue-tsc": "^2.0.0"
  }
}
